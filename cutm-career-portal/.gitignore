
---

# 📄 `.gitignore`

```gitignore
# Dependencies
node_modules/
npm-debug.log
yarn-error.log

# Production builds
dist/
build/

# Environment variables
.env
.env.local
.env.development
.env.test
.env.production

# Vite
.vite/

# Logs
logs/
*.log

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/

# React / frontend cache
coverage/

# Backend logs
server/logs/

# Optional
*.pem
*.key